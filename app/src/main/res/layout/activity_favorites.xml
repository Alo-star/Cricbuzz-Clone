<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#F5F5F5">

    <LinearLayout android:layout_width="match_parent" android:layout_height="60dp"
        android:background="#008C5A" android:orientation="horizontal"
        android:gravity="center_vertical" android:paddingStart="8dp" android:paddingEnd="16dp">
        <TextView android:id="@+id/backBtn" android:layout_width="48dp" android:layout_height="48dp"
            android:text="&#8592;" android:textColor="#FFFFFF" android:textSize="24sp" android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="My Favorites" android:textColor="#FFFFFF" android:textSize="20sp"
            android:textStyle="bold" android:layout_marginStart="4dp"/>
    </LinearLayout>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Favorite Teams" android:textStyle="bold" android:textSize="15sp"
        android:padding="16dp" android:textColor="#222222"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/favoriteTeamsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="240dp"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Favorite Matches" android:textStyle="bold" android:textSize="15sp"
        android:padding="16dp" android:textColor="#222222"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/favoriteMatchesRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <TextView android:id="@+id/emptyText" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:gravity="center" android:padding="24dp" android:text="No favorites yet.\nTap the star on any team or match to add it here."
        android:textColor="#888888" android:visibility="gone"/>

</LinearLayout>
