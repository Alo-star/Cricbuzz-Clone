<?xml version="1.0" encoding="utf-8"?>
<com.facebook.shimmer.ShimmerFrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/shimmer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:shimmer_duration="1000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="16dp">

        <View android:layout_width="180dp" android:layout_height="14dp" android:background="#E0E0E0" />
        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="10dp" android:background="#EEEEEE" />
        <View android:layout_width="120dp" android:layout_height="18dp" android:background="#E0E0E0" />
        <View android:layout_width="120dp" android:layout_height="18dp" android:layout_marginTop="10dp" android:background="#E0E0E0" />
        <View android:layout_width="match_parent" android:layout_height="36dp" android:layout_marginTop="14dp" android:background="#EFEFEF" />

    </LinearLayout>

</com.facebook.shimmer.ShimmerFrameLayout>
